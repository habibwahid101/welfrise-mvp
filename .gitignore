# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
Thumbs.db
Desktop.ini
*.pem
*.key
*.p12
*.pfx

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# local tooling and temporary files
.idea/
.vscode/
*.swp
*.swo
*.tmp
*.temp
.cache/
.turbo/
.supabase/

# local database exports
*.dump
*.sql.gz

# typescript
*.tsbuildinfo
next-env.d.ts

!.env.example
